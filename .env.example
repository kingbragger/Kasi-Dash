# ─── API Server ───────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret used to sign JWT tokens (required — use a long random string)
SESSION_SECRET=change-me-to-a-long-random-secret

# Comma-separated list of allowed CORS origins.
# Set to your Netlify URL when deploying the API to Render/Railway/Fly.io.
# Leave blank or set to "*" to allow all origins (dev only).
ALLOWED_ORIGINS=https://yoursite.netlify.app,https://yourdomain.com

# ─── Ozow Payments (optional — test mode is used when these are absent) ───────
OZOW_SITE_CODE=
OZOW_PRIVATE_KEY=
OZOW_API_KEY=
OZOW_IS_TEST=true

# ─── Frontend (kasidash) — set these in Netlify dashboard ────────────────────
# Full URL of the deployed API server (no trailing slash).
# Leave blank when frontend and API are on the same origin (Replit dev).
VITE_API_URL=https://your-api.onrender.com
